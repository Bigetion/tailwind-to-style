{
  "name": "tailwind-to-style",
  "version": "3.2.2",
  "description": "Runtime Tailwind CSS to inline styles converter. Zero build step, SSR support, tree-shakeable. Works with React, Vue, Svelte, vanilla JS.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "browser": "dist/index.min.js",
  "unpkg": "dist/index.min.js",
  "jsdelivr": "dist/index.min.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./tws": {
      "types": "./dist/core/tws.d.ts",
      "import": "./dist/core/tws.esm.js",
      "require": "./dist/core/tws.cjs"
    },
    "./twsx": {
      "types": "./dist/core/twsx.d.ts",
      "import": "./dist/core/twsx.esm.js",
      "require": "./dist/core/twsx.cjs"
    },
    "./twsx-variants": {
      "types": "./dist/core/twsxVariants.d.ts",
      "import": "./dist/core/twsxVariants.esm.js",
      "require": "./dist/core/twsxVariants.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.esm.js",
      "require": "./dist/utils/index.cjs"
    },
    "./cx": {
      "types": "./dist/cx.d.ts",
      "import": "./dist/cx.esm.js",
      "require": "./dist/cx.cjs"
    },
    "./preflight.css": "./preflight.css",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "types",
    "preflight.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "build:watch": "rollup -c rollup.config.js --watch",
    "dev": "rollup -c rollup.config.js --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:examples": "node examples/test/node-test.js",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "version": "git add -A",
    "postversion": "git push && git push --tags",
    "prettify": "prettier --write \"src/**/*.js\" \"examples/**/*.js\" \"tests/**/*.js\"",
    "prettify:src": "prettier --write \"src/**/*.js\"",
    "prettify:examples": "prettier --write \"examples/**/*.js\"",
    "analyze": "rollup -c rollup.config.js --environment ANALYZE"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bigetion/tailwind-to-style.git"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "css",
    "stylesheet",
    "inline-styles",
    "runtime-css",
    "css-in-js",
    "zero-build",
    "ssr",
    "server-side-rendering",
    "tree-shakeable",
    "variants",
    "style-converter",
    "react",
    "vue",
    "svelte"
  ],
  "author": "Bigetion",
  "license": "MIT",
  "funding": {
    "type": "individual",
    "url": "https://buymeacoffee.com/bigetion"
  },
  "bugs": {
    "url": "https://github.com/Bigetion/tailwind-to-style/issues"
  },
  "homepage": "https://github.com/Bigetion/tailwind-to-style#readme",
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.28.5",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "babel-jest": "^30.0.0",
    "babel-loader": "^10.0.0",
    "chokidar": "^4.0.1",
    "eslint": "^9.15.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup": "^4.27.4",
    "rollup-plugin-copy": "^3.5.0",
    "terser": "^5.43.1",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  }
}
